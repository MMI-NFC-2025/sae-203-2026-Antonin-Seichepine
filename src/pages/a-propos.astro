---
import Layout from "../layouts/Layout.astro";
---

<Layout titre="À propos">
    <!-- Bandeau hero -->
    <section class="relative">
        <div class="h-24 bg-[url('/hero-bg.jpg')] bg-cover bg-center">
            <div class="absolute inset-0 bg-primary/85"></div>
        </div>
    </section>

    <!-- Présentation -->
    <section class="px-6 py-10">
        <div class="mygrid">
            <div class="max-w-md mx-auto lg:col-start-3 lg:col-span-8 lg:max-w-none lg:mx-0">
        <h2 class="font-heading text-3xl text-cream text-center mb-8 font-bold">
            La magie de Noël au cœur de la musique baroque
        </h2>

        <div class="text-cream font-body text-sm leading-relaxed mb-8">
            <p class="mb-4">
                Festicloze est un festival musical baroque de Noël qui se
                déroule à Montbéliard pendant trois jours magiques entre le 20
                et le 23 décembre. Dans les lieux emblématiques de la ville,
                nous proposons une expérience unique alliant concerts
                exceptionnels, illuminations féeriques et marché d'artisans
                locaux.
            </p>
        </div>

        <!-- Nos valeurs -->
        <h3 class="font-heading text-xl text-cream mb-4 font-bold">
            Nos valeurs
        </h3>
        <div class="rounded-2xl border border-primary-light/60 bg-primary-light/15 p-6 mb-8">
            <ul class="text-cream font-body text-sm leading-relaxed list-disc pl-5">
                <li class="mb-2">
                    <strong>Le Partage</strong> &ndash; R&eacute;unir les g&eacute;n&eacute;rations autour de
                    la musique et de la convivialit&eacute;
                </li>
                <li class="mb-2">
                    <strong>La Tradition</strong> &ndash; C&eacute;l&eacute;brer l'h&eacute;ritage musical baroque
                    et le patrimoine de Montb&eacute;liard
                </li>
                <li class="mb-2">
                    <strong>L&apos;&Eacute;merveillement</strong> &ndash; Cr&eacute;er la magie de No&euml;l par
                    la musique et la sc&eacute;nographie
                </li>
            </ul>
        </div>

        <!-- Notre mission -->
        <h3 class="font-heading text-xl text-cream mb-4 font-bold">
            Notre mission
        </h3>
        <p class="text-cream font-body text-sm leading-relaxed">
            Rendre la musique baroque accessible à tous dans une atmosphère
            festive et familiale, tout en valorisant l'attractivité culturelle
            et les savoir-faire locaux de Montbéliard.
        </p>
            </div>
        </div>
    </section>

    <!-- Historique -->
    <section class="px-6 py-10">
        <div class="mygrid">
            <div class="max-w-md mx-auto lg:col-start-3 lg:col-span-8 lg:max-w-none lg:mx-0">
                <h2 class="font-heading text-2xl text-cream text-center mb-6 font-bold">
                    Historique du festival
                </h2>
                <div class="rounded-2xl border border-primary-light/60 bg-primary-light/15 p-6 lg:p-8">
                    <p class="text-cream font-body text-sm leading-relaxed">
                    Créé à Montbéliard pour faire découvrir la musique baroque au grand public,
                    Festicloze rassemble depuis ses débuts artistes, habitants et visiteurs autour
                    d’un rendez-vous culturel de fin d’année. Le festival a grandi avec un objectif
                    constant : proposer une programmation exigeante, festive et accessible à tous.
                </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Équipe -->
    <section class="px-6 py-10">
        <div class="mygrid">
            <div class="max-w-md mx-auto lg:col-start-3 lg:col-span-8 lg:max-w-none lg:mx-0">
                <h2 class="font-heading text-2xl text-cream text-center mb-6 font-bold">
                    Équipe
                </h2>
                <ul class="grid grid-cols-1 gap-3 lg:grid-cols-2 lg:gap-4">
                    <li class="rounded-2xl border border-primary-light/60 bg-primary-light/15 px-4 py-3 text-cream font-body text-sm">Antonin Seichepine</li>
                    <li class="rounded-2xl border border-primary-light/60 bg-primary-light/15 px-4 py-3 text-cream font-body text-sm">Camille Martin</li>
                    <li class="rounded-2xl border border-primary-light/60 bg-primary-light/15 px-4 py-3 text-cream font-body text-sm">Lucas Bernard</li>
                    <li class="rounded-2xl border border-primary-light/60 bg-primary-light/15 px-4 py-3 text-cream font-body text-sm">Emma Leroy</li>
                </ul>
            </div>
        </div>
    </section>

<!-- FAQ -->
    <!-- FAQ -->
    <!-- FAQ -->
    <section class="px-6 pt-6 pb-10">
        <div class="mygrid">
            <div class="max-w-md mx-auto lg:col-start-3 lg:col-span-8 lg:max-w-none lg:mx-0">
        <h2 class="font-heading text-2xl text-cream text-center mb-8 font-bold">
            FAQ
        </h2>

        <div class="flex flex-col" style="gap: 1.5rem;">
            <!-- Question 1 -->
            <div
                class="bg-card rounded-xl"
                style="padding: 1.25rem 1.5rem; text-align: left;"
            >
                <button
                    class="faq-toggle w-full flex items-start justify-between text-left"
                >
                    <span class="font-body font-semibold text-text-dark text-sm"
                        >Quelles sont les dates et horaires des concerts ?</span
                    >
                    <span
                        class="faq-icon font-body text-text-dark text-xl"
                        style="margin-left: 2rem; flex-shrink: 0;">+</span
                    >
                </button>
                <div class="faq-content hidden" style="margin-top: 0.75rem;">
                    <p
                        class="font-body text-text-dark text-sm leading-relaxed"
                        style="text-align: left;"
                    >
                        Les concerts se tiennent du 20 au 23 décembre, chaque
                        soirée à partir de 18h, avec des animations dès 14h dans
                        certains lieux.
                    </p>
                </div>
            </div>

            <!-- Question 2 -->
            <div
                class="bg-card rounded-xl"
                style="padding: 1.25rem 1.5rem; text-align: left;"
            >
                <button
                    class="faq-toggle w-full flex items-start justify-between text-left"
                >
                    <span class="font-body font-semibold text-text-dark text-sm"
                        >Comment réserver mes billets ?</span
                    >
                    <span
                        class="faq-icon font-body text-text-dark text-xl"
                        style="margin-left: 2rem; flex-shrink: 0;">+</span
                    >
                </button>
                <div class="faq-content hidden" style="margin-top: 0.75rem;">
                    <p
                        class="font-body text-text-dark text-sm leading-relaxed"
                        style="text-align: left;"
                    >
                        Via le bouton "Réserver mes billets" sur la page
                        d'accueil : vous choisissez votre concert et recevez la
                        confirmation immédiatement par e-mail.
                    </p>
                </div>
            </div>

            <!-- Question 3 -->
            <div
                class="bg-card rounded-xl"
                style="padding: 1.25rem 1.5rem; text-align: left;"
            >
                <button
                    class="faq-toggle w-full flex items-start justify-between text-left"
                >
                    <span class="font-body font-semibold text-text-dark text-sm"
                        >Les lieux sont-ils accessibles aux personnes à mobilité
                        réduite ?</span
                    >
                    <span
                        class="faq-icon font-body text-text-dark text-xl"
                        style="margin-left: 2rem; flex-shrink: 0;">+</span
                    >
                </button>
                <div class="faq-content hidden" style="margin-top: 0.75rem;">
                    <p
                        class="font-body text-text-dark text-sm leading-relaxed"
                        style="text-align: left;"
                    >
                        Oui, tous les lieux du festival sont accessibles aux
                        personnes à mobilité réduite.
                    </p>
                </div>
            </div>
        </div>
            </div>
        </div>
    </section>
</Layout>

<script>
    // @ts-nocheck
    const toggles = document.querySelectorAll(".faq-toggle");

    toggles.forEach((toggle) => {
        toggle.addEventListener("click", () => {
            const content = toggle.nextElementSibling;
            const icon = toggle.querySelector(".faq-icon");

            content.classList.toggle("hidden");
            icon.textContent = content.classList.contains("hidden") ? "+" : "-";
        });
    });
</script>
