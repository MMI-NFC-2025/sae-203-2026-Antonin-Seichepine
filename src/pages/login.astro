---
import Layout from "../layouts/Layout.astro";
import { loginUser, isUserAuthenticated } from "../js/backend.mjs";

const url = new URL(Astro.request.url);
const nextParam = url.searchParams.get("next");
const next =
    nextParam && nextParam.startsWith("/") && !nextParam.startsWith("//")
        ? nextParam
        : "/artistes/add";

const token = Astro.cookies.get("pb_auth_token")?.value;
const alreadyConnected = await isUserAuthenticated(token);

if (alreadyConnected) {
    return Astro.redirect(next);
}

let message = "";

if (Astro.request.method === "POST") {
    const formData = await Astro.request.formData();

    const email = String(formData.get("email") || "");
    const password = String(formData.get("password") || "");
    const nextForm = String(formData.get("next") || "");
    const redirectTo =
        nextForm && nextForm.startsWith("/") && !nextForm.startsWith("//")
            ? nextForm
            : next;

    const authData = await loginUser(email, password);

    if (authData?.token) {
        Astro.cookies.set("pb_auth_token", authData.token, {
            path: "/",
            httpOnly: true,
            sameSite: "lax",
            secure: url.protocol === "https:",
            maxAge: 60 * 60 * 8,
        });

        return Astro.redirect(redirectTo);
    }

    message = "Identifiants invalides.";
}
---

<Layout titre="Connexion">
    <section class="px-6 py-10 max-w-md mx-auto">
        <h2 class="font-heading text-3xl text-cream text-center mb-8 font-bold">
            Connexion
        </h2>

        {
            message && (
                <p class="font-body text-sm text-accent text-center mb-4">
                    {message}
                </p>
            )
        }

        <form method="POST" class="flex flex-col gap-4">
            <input type="hidden" name="next" value={next} />

            <div>
                <label class="font-body font-bold text-cream text-sm mb-2 block">
                    Email :
                </label>
                <input
                    type="email"
                    name="email"
                    required
                    class="w-full bg-transparent rounded-xl text-cream font-body text-sm placeholder-cream-dark/60 focus:outline-none transition-colors border-2 border-[#8B1538] px-5 py-3"
                />
            </div>

            <div>
                <label class="font-body font-bold text-cream text-sm mb-2 block">
                    Mot de passe :
                </label>
                <input
                    type="password"
                    name="password"
                    required
                    class="w-full bg-transparent rounded-xl text-cream font-body text-sm placeholder-cream-dark/60 focus:outline-none transition-colors border-2 border-[#8B1538] px-5 py-3"
                />
            </div>

            <div class="text-center mt-2">
                <button
                    type="submit"
                    class="inline-block bg-accent text-primary font-body text-lg px-8 py-3 rounded-full border-2 border-accent hover:bg-transparent hover:text-accent transition-colors"
                >
                    Se connecter
                </button>
            </div>
        </form>
    </section>
</Layout>
