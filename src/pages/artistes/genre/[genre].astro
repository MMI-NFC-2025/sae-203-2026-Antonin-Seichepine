---
import Layout from "../../../layouts/Layout.astro";
import ArtisteCard from "../../../components/ArtisteCard.astro";
import { getImage } from "astro:assets";
import { getArtistesByDate } from "../../../js/backend.mjs";
import heroBg from "../../../assets/images/hero-bg.jpg";

// Récupérer le genre depuis l'URL
const { genre } = Astro.params;

// Récupérer tous les artistes et filtrer par genre
const tousArtistes = await getArtistesByDate();
const artistes = tousArtistes.filter(
    (a) =>
        a.genre_musical.toLowerCase() ===
        decodeURIComponent(genre).toLowerCase(),
);

// Redirection si aucun artiste trouvé
if (artistes.length === 0) {
    return Astro.redirect("/artistes");
}

// Liste des genres uniques pour les filtres
const genres = [...new Set(tousArtistes.map((a) => a.genre_musical))];
const heroBgOptimized = await getImage({ src: heroBg });
---

<Layout titre={`Artistes - ${decodeURIComponent(genre)}`}>
    <!-- Bandeau hero -->
    <section class="relative">
        <div
            class="h-24 bg-cover bg-center"
            style={`background-image:url(${heroBgOptimized.src})`}
        >
            <div class="absolute inset-0 bg-primary/85"></div>
        </div>
    </section>

    <!-- Filtres -->
    <section class="px-6 pt-10">
        <div class="mygrid">
        <h2 class="font-heading text-3xl text-cream text-center mb-6 font-bold lg:col-span-12">
            Artistes
        </h2>

        <div class="flex flex-wrap gap-2 mb-8 justify-center lg:col-start-2 lg:col-span-10">
            <a
                href="/artistes"
                class="font-body text-xs bg-transparent text-cream px-3 py-1 rounded-lg"
                style="border: 1px solid #8B1538;"
            >
                Tous
            </a>
            {
                genres.map((g) => (
                    <a
                        href={`/artistes/genre/${encodeURIComponent(g)}`}
                        class={`font-body text-xs px-3 py-1 rounded-lg ${g.toLowerCase() === decodeURIComponent(genre).toLowerCase() ? "bg-accent text-primary" : "bg-transparent text-cream"}`}
                        style={
                            g.toLowerCase() !==
                            decodeURIComponent(genre).toLowerCase()
                                ? "border: 1px solid #8B1538;"
                                : ""
                        }
                    >
                        {g}
                    </a>
                ))
            }
        </div>
        </div>
    </section>

    <!-- Liste filtrée -->
    <section class="px-6 pb-10">
        <div class="mygrid">
        <div class="flex flex-col gap-6 max-w-md mx-auto lg:col-span-12 lg:max-w-none lg:mx-0 lg:grid lg:grid-cols-3 lg:gap-8">
            {artistes.map((artiste) => <ArtisteCard artiste={artiste} />)}
        </div>
        </div>
    </section>
</Layout>
