---
import Layout from "../../layouts/Layout.astro";
import ArtisteCard from "../../components/ArtisteCard.astro";
import { getImage } from "astro:assets";
import { getArtistesByDate } from "../../js/backend.mjs";
import heroBg from "../../assets/images/hero-bg.jpg";

// Récupérer tous les artistes triés par date
const artistes = await getArtistesByDate();
const heroBgOptimized = await getImage({ src: heroBg });

// Listes uniques pour les filtres
const genres = [...new Set(artistes.map((a) => a.genre_musical))];
const jours = [
    ...new Set(artistes.map((a) => new Date(a.date_debut).getUTCDate())),
].sort();
---

<Layout titre="Artistes">
    <!-- Bandeau hero -->
    <section class="relative">
        <div
            class="h-24 bg-cover bg-center"
            style={`background-image:url(${heroBgOptimized.src})`}
        >
            <div class="absolute inset-0 bg-primary/85"></div>
        </div>
    </section>

    <!-- Liste des artistes -->
    <section class="px-6 py-10">
        <div class="mygrid">
        <h2 class="font-heading text-3xl text-cream text-center mb-6 font-bold lg:col-span-12">
            Artistes
        </h2>

        <!-- Filtres par genre -->
        <div class="flex flex-wrap gap-2 mb-4 justify-center max-w-md mx-auto lg:col-start-2 lg:col-span-10 lg:max-w-none lg:mx-0">
            <span class="font-body text-xs text-cream-dark mr-1">Genre :</span>
            {
                genres.map((g) => (
                    <a
                        href={`/artistes/genre/${encodeURIComponent(g)}`}
                        class="font-body text-xs bg-transparent text-cream px-3 py-1 rounded-lg"
                        style="border: 1px solid #8B1538;"
                    >
                        {g}
                    </a>
                ))
            }
        </div>

        <!-- Filtres par jour -->
        <div class="flex flex-wrap gap-2 mb-8 justify-center max-w-md mx-auto lg:col-start-2 lg:col-span-10 lg:max-w-none lg:mx-0">
            <span class="font-body text-xs text-cream-dark mr-1">Jour :</span>
            {
                jours.map((j) => (
                    <a
                        href={`/artistes/jour/${j}`}
                        class="font-body text-xs bg-transparent text-cream px-3 py-1 rounded-lg"
                        style="border: 1px solid #8B1538;"
                    >
                        {j} Déc
                    </a>
                ))
            }
        </div>

        <div class="flex flex-col gap-6 max-w-md mx-auto lg:col-span-12 lg:max-w-none lg:mx-0 lg:grid lg:grid-cols-3 lg:gap-8">
            {artistes.map((artiste) => <ArtisteCard artiste={artiste} />)}
        </div>
        </div>
    </section>
</Layout>
