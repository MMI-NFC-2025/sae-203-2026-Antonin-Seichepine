---
import Layout from "../../layouts/Layout.astro";
import { getArtiste, getImageUrl } from "../../js/backend.mjs";

// Récupérer l'id depuis l'URL
const { id } = Astro.params;

// Récupérer les infos de l'artiste
const artiste = await getArtiste(id);

// Redirection si l'artiste n'existe pas
if (!artiste) {
    return Astro.redirect("/artistes");
}

// Formater la date
const date = new Date(artiste.date_debut);
const jour = date.getUTCDate();
const heure = date.getUTCHours();
const minutes = date.getUTCMinutes().toString().padStart(2, "0");
const dateTexte = `${jour} Décembre • ${heure}h${minutes}`;

// Récupérer le nom de la scène via expand
const scene = artiste.expand?.scene;

// Toutes les images (photo principale + galerie)
const allImages = [artiste.photo, ...(artiste.galerie || [])];
---

<Layout titre={artiste.nom_artiste}>
    <!-- Bandeau hero -->
    <section class="relative">
        <div class="h-24 bg-[url('/hero-bg.jpg')] bg-cover bg-center">
            <div class="absolute inset-0 bg-primary/85"></div>
        </div>
    </section>

    <!-- Détail artiste -->
    <section class="px-6 py-10">
        <div class="mygrid">
            <div class="max-w-md mx-auto lg:col-start-3 lg:col-span-8 lg:max-w-none lg:mx-0">
        <!-- Nom -->
        <h1 class="font-heading text-3xl text-cream text-center mb-6 font-bold">
            {artiste.nom_artiste}
        </h1>

        <!-- Card avec carrousel -->
        <div class="overflow-hidden">
            <!-- Carrousel images -->
            <div class="relative">
                <div
                    id="artiste-carrousel"
                    class="flex transition-transform duration-500"
                >
                    {
                        allImages.map((photo) => (
                            <div class="w-full flex-shrink-0">
                                <img
                                    src={getImageUrl(artiste, photo)}
                                    alt={artiste.nom_artiste}
                                    class="w-full h-72 object-cover rounded-t-xl"
                                />
                            </div>
                        ))
                    }
                </div>
                <!-- Flèches si plusieurs images -->
                {
                    allImages.length > 1 && (
                        <>
                            <button
                                id="art-prev"
                                class="absolute left-2 top-1/2 -translate-y-1/2 text-cream text-3xl bg-primary/50 rounded-full w-10 h-10 flex items-center justify-center"
                            >
                                &lt;
                            </button>
                            <button
                                id="art-next"
                                class="absolute right-2 top-1/2 -translate-y-1/2 text-cream text-3xl bg-primary/50 rounded-full w-10 h-10 flex items-center justify-center"
                            >
                                &gt;
                            </button>
                        </>
                    )
                }
            </div>

            <!-- Infos sous le carrousel -->
            <div class="p-5 bg-card rounded-b-xl">
                <div class="flex flex-col gap-1 mb-4">
                    <p class="font-body font-semibold text-text-accent text-sm">
                        {artiste.genre_musical}
                    </p>
                    <p class="font-body text-text-dark text-sm">{dateTexte}</p>
                    {
                        scene && (
                            <a
                                href={`/scenes/${scene.id}`}
                                class="font-body text-text-accent text-sm hover:underline"
                            >
                                {scene.nom_scene}
                            </a>
                        )
                    }
                </div>

                <!-- Description -->
                <p class="font-body text-text-dark text-sm leading-relaxed">
                    {artiste.description_artiste}
                </p>
            </div>
        </div>

        <!-- Indicateurs -->
        {
            allImages.length > 1 && (
                <div class="flex justify-center gap-2 mt-4">
                    {allImages.map((_, i) => (
                        <span
                            class={`w-3 h-3 rounded-full ${i === 0 ? "bg-accent" : "bg-primary-light"}`}
                            data-art-dot={i}
                        />
                    ))}
                </div>
            )
        }

        <!-- Bouton retour -->
        <div class="mt-8 text-center">
            <a
                href="/artistes"
                class="inline-block bg-accent text-primary font-body px-6 py-2 rounded-full border-2 border-accent hover:bg-transparent hover:text-accent transition-colors"
            >
                ← Tous les artistes
            </a>
        </div>
            </div>
        </div>
    </section>
</Layout>

<script>
    // @ts-nocheck
    const carrousel = document.getElementById("artiste-carrousel");
    const prev = document.getElementById("art-prev");
    const next = document.getElementById("art-next");
    const dots = document.querySelectorAll("[data-art-dot]");

    if (carrousel) {
        let current = 0;
        const total = carrousel.children.length;

        function goTo(index) {
            current = (index + total) % total;
            carrousel.style.transform = `translateX(-${current * 100}%)`;
            dots.forEach((dot, i) => {
                dot.classList.toggle("bg-accent", i === current);
                dot.classList.toggle("bg-primary-light", i !== current);
            });
        }

        if (prev) prev.addEventListener("click", () => goTo(current - 1));
        if (next) next.addEventListener("click", () => goTo(current + 1));
    }
</script>
