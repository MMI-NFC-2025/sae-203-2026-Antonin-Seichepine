---
import Layout from '../layouts/Layout.astro';
import { getImage } from 'astro:assets';
import { getArtistesByDate } from '../js/backend.mjs';
import heroBg from '../assets/images/hero-bg.jpg';

const heroBgOptimized = await getImage({ src: heroBg });

// Récupérer tous les artistes triés par date
const artistes = await getArtistesByDate();
const url = new URL(Astro.request.url);
const horaire = url.searchParams.get('horaire') || '';

const horaires = [
  ...new Set(
    artistes.map((artiste) => {
      const date = new Date(artiste.date_debut);
      return `${date.getUTCHours().toString().padStart(2, '0')}h${date.getUTCMinutes().toString().padStart(2, '0')}`;
    }),
  ),
].sort();

const artistesFiltres = horaire
  ? artistes.filter((artiste) => {
      const date = new Date(artiste.date_debut);
      const horaireArtiste = `${date.getUTCHours().toString().padStart(2, '0')}h${date.getUTCMinutes().toString().padStart(2, '0')}`;
      return horaireArtiste === horaire;
    })
  : artistes;

// Grouper les artistes par date
const parJour = {};
artistesFiltres.forEach((artiste) => {
  const date = new Date(artiste.date_debut);
  const jour = date.getUTCDate();
  const cle = `${jour} Décembre`;
  if (!parJour[cle]) {
    parJour[cle] = [];
  }
  parJour[cle].push(artiste);
});

// Trier les artistes par heure dans chaque jour
Object.values(parJour).forEach((artistesJour) => {
  artistesJour.sort((a, b) => new Date(a.date_debut) - new Date(b.date_debut));
});
---

<Layout titre="Programme">

  <!-- Bandeau hero -->
  <section class="relative">
    <div
      class="h-24 bg-cover bg-center"
      style={`background-image:url(${heroBgOptimized.src})`}
    >
      <div class="absolute inset-0 bg-primary/85"></div>
    </div>
  </section>

  <!-- Programme -->
  <section class="px-6 py-10">
    <div class="mygrid">
    <h2 class="font-heading text-3xl text-cream text-center mb-8 font-bold lg:col-span-12">Programme</h2>

    <div class="flex flex-wrap gap-2 mb-4 justify-center max-w-md mx-auto lg:col-start-2 lg:col-span-10 lg:max-w-none lg:mx-0">
      <span class="font-body text-xs text-cream-dark mr-1">Horaire :</span>
      <a
        href="/programme"
        class={`font-body text-xs px-3 py-1 rounded-lg ${horaire === '' ? 'bg-accent text-primary' : 'bg-transparent text-cream'}`}
        style={horaire !== '' ? 'border: 1px solid #8B1538;' : ''}
      >
        Tous
      </a>
      {horaires.map((h) => (
        <a
          href={`/programme?horaire=${encodeURIComponent(h)}`}
          class={`font-body text-xs px-3 py-1 rounded-lg ${h === horaire ? 'bg-accent text-primary' : 'bg-transparent text-cream'}`}
          style={h !== horaire ? 'border: 1px solid #8B1538;' : ''}
        >
          {h}
        </a>
      ))}
    </div>

    <div class="text-center mb-8 lg:col-span-12">
      <a
        href="/programme-festicloze.pdf"
        download
        class="inline-block bg-accent text-primary font-body text-sm px-6 py-2 rounded-full border-2 border-accent hover:bg-transparent hover:text-accent transition-colors"
      >
        Télécharger le programme PDF
      </a>
    </div>

    <div class="flex flex-col gap-6 max-w-md mx-auto lg:col-span-12 lg:max-w-none lg:mx-0 lg:grid lg:grid-cols-2 lg:gap-8">
      {Object.entries(parJour).map(([jour, artistesJour]) => (
        <div class="bg-card rounded-xl p-5">
          <!-- Date + tag -->
          <div class="flex items-center justify-between mb-3">
            <h3 class="font-body font-bold text-text-accent text-2xl">{jour}</h3>
            <span class="font-body text-sm text-text-accent px-4 py-1 rounded-lg" style="background-color: #E8C4A7;">
              {artistesJour[0].genre_musical}
            </span>
          </div>

          <!-- Artistes du jour -->
          {artistesJour.map((artiste) => (
            <div class="mb-3 last:mb-0">
              <a href={`/artistes/${artiste.id}`} class="font-body font-semibold text-text-dark text-lg hover:text-text-accent transition-colors">
                {artiste.nom_artiste}
              </a>
              <p class="font-body text-text-dark text-sm">
                {artiste.expand?.scene?.nom_scene} • {new Date(artiste.date_debut).getUTCHours()}h{new Date(artiste.date_debut).getUTCMinutes().toString().padStart(2, '0')}
              </p>
            </div>
          ))}
        </div>
      ))}
    </div>
    </div>
  </section>

</Layout>
