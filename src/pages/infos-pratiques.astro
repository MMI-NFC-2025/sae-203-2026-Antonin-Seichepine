---
import Layout from "../layouts/Layout.astro";
import { Image, getImage } from "astro:assets";
import heroBg from "../assets/images/hero-bg.jpg";
import partenaireVille from "../assets/images/partenaire-ville.png";
import partenaireRegion from "../assets/images/partenaire-region.png";
import partenaireTourisme from "../assets/images/partenaire-tourisme.png";
import partenaireConservatoire from "../assets/images/partenaire-conservatoire.png";

const heroBgOptimized = await getImage({ src: heroBg });
---

<Layout titre="Infos pratiques">
    <!-- Bandeau hero -->
    <section class="relative">
        <div
            class="h-24 bg-cover bg-center"
            style={`background-image:url(${heroBgOptimized.src})`}
        >
            <div class="absolute inset-0 bg-primary/85"></div>
        </div>
    </section>

    <!-- Infos pratiques -->
    <section class="px-6 py-10">
        <div class="mygrid">
        <h2 class="font-heading text-3xl text-cream text-center mb-8 font-bold lg:col-span-12">
            Infos pratiques
        </h2>

        <div class="flex flex-col gap-4 max-w-md mx-auto lg:col-span-12 lg:max-w-none lg:mx-0 lg:grid lg:grid-cols-3 lg:gap-8">
            <!-- Tarifs -->
            <div class="bg-card rounded-xl p-5">
                <h3
                    class="font-body font-semibold text-text-accent text-lg mb-1"
                >
                    Tarifs
                </h3>
                <p class="font-body text-text-dark text-sm">
                    À partir de 15€ • Tarif famille disponible
                </p>
            </div>

            <!-- Transport -->
            <div class="bg-card rounded-xl p-5">
                <h3
                    class="font-body font-semibold text-text-accent text-lg mb-1"
                >
                    Transport
                </h3>
                <p class="font-body text-text-dark text-sm">
                    Parking gratuit • Navettes entre les lieux
                </p>
            </div>

            <!-- Hébergement -->
            <div class="bg-card rounded-xl p-5">
                <h3
                    class="font-body font-semibold text-text-accent text-lg mb-1"
                >
                    Hébergement
                </h3>
                <p class="font-body text-text-dark text-sm">
                    Partenariats hôtels • Offres spéciales
                </p>
            </div>
        </div>
        </div>
    </section>

    <!-- Partenaires -->
    <section class="px-6 pb-10">
        <div class="mygrid">
        <h2 class="font-heading text-2xl text-cream text-center mb-6 font-bold lg:col-span-12">
            Nos partenaires
        </h2>

        <div class="grid grid-cols-2 gap-4 max-w-md mx-auto lg:col-start-3 lg:col-span-8 lg:max-w-none lg:mx-0 lg:grid-cols-4 lg:gap-8">
            <div
                class="bg-card rounded-xl p-4 flex items-center justify-center"
            >
                <Image
                    src={partenaireVille}
                    width={3840}
                    height={2040}
                    alt="Ville de Montbéliard"
                    class="h-12 object-contain"
                />
            </div>
            <div
                class="bg-card rounded-xl p-4 flex items-center justify-center"
            >
                <Image
                    src={partenaireRegion}
                    width={1464}
                    height={1110}
                    alt="Région Bourgogne-Franche-Comté"
                    class="h-12 object-contain"
                />
            </div>
            <div
                class="bg-card rounded-xl p-4 flex items-center justify-center"
            >
                <Image
                    src={partenaireTourisme}
                    width={500}
                    height={666}
                    alt="Office de Tourisme"
                    class="h-12 object-contain"
                />
            </div>
            <div
                class="bg-card rounded-xl p-4 flex items-center justify-center"
            >
                <Image
                    src={partenaireConservatoire}
                    width={240}
                    height={240}
                    alt="Conservatoire"
                    class="h-12 object-contain"
                />
            </div>
        </div>
        </div>
    </section>
</Layout>
