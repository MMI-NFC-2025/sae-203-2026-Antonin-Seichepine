---
import Layout from "../../layouts/Layout.astro";
import SceneCard from "../../components/SceneCard.astro";
import { getImage } from "astro:assets";
import { getScenesByName } from "../../js/backend.mjs";
import heroBg from "../../assets/images/hero-bg.jpg";

// Récupérer toutes les scènes triées par nom
const scenes = await getScenesByName();
const heroBgOptimized = await getImage({ src: heroBg });
---

<Layout titre="Scènes">
    <!-- Bandeau hero -->
    <section class="relative">
        <div
            class="h-24 bg-cover bg-center"
            style={`background-image:url(${heroBgOptimized.src})`}
        >
            <div class="absolute inset-0 bg-primary/85"></div>
        </div>
    </section>

    <!-- Liste des scènes -->
    <section class="px-6 py-10">
        <div class="mygrid">
        <h2 class="font-heading text-3xl text-cream text-center mb-8 font-bold lg:col-span-12">
            Lieux emblématiques
        </h2>

        <div class="flex flex-col gap-6 max-w-md mx-auto lg:col-span-12 lg:max-w-none lg:mx-0 lg:grid lg:grid-cols-3 lg:gap-8">
            {scenes.map((scene) => <SceneCard scene={scene} />)}
        </div>
        </div>
    </section>
</Layout>
