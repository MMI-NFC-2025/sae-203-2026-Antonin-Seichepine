---
import Layout from "../../layouts/Layout.astro";
import ArtisteCard from "../../components/ArtisteCard.astro";
import PbImage from "../../components/PbImage.astro";
import {
    getScene,
    getArtistesBySceneId,
} from "../../js/backend.mjs";

// Récupérer l'id depuis l'URL
const { id } = Astro.params;

// Récupérer les infos de la scène
const scene = await getScene(id);

// Redirection si la scène n'existe pas
if (!scene) {
    return Astro.redirect("/scenes");
}

// Récupérer les artistes de cette scène
const artistes = await getArtistesBySceneId(id);
---

<Layout titre={scene.nom_scene}>
    <!-- Bandeau hero -->
    <section class="relative">
        <div class="h-24 bg-[url('/hero-bg.jpg')] bg-cover bg-center">
            <div class="absolute inset-0 bg-primary/85"></div>
        </div>
    </section>

    <!-- Détail scène -->
    <section class="px-6 py-10">
        <div class="mygrid">
            <div class="max-w-md mx-auto lg:col-start-3 lg:col-span-8 lg:max-w-none lg:mx-0">
        <!-- Nom -->
        <h1 class="font-heading text-3xl text-cream text-center mb-6 font-bold">
            {scene.nom_scene}
        </h1>

        <!-- Card scène -->
        <div class="overflow-hidden">
            <PbImage
                record={scene}
                field={scene.photo}
                alt={scene.nom_scene}
                classImg="w-full h-72 object-cover rounded-t-xl"
            />
            <div class="p-5 bg-card rounded-b-xl">
                <p class="font-body text-text-dark text-s mb-2">
                    {scene.localisation}
                </p>
                <p class="font-body text-text-dark text-sm leading-relaxed">
                    {scene.description_scene}
                </p>
                <p class="font-body text-text-dark text-xs mt-3">
                    Capacité : {scene.capacite} places
                </p>
            </div>
        </div>
            </div>
        </div>
    </section>

    <!-- Artistes sur cette scène -->
    {
        artistes.length > 0 && (
            <section class="px-6 pb-10">
                <div class="mygrid">
                    <div class="max-w-md mx-auto lg:col-start-2 lg:col-span-10 lg:max-w-none lg:mx-0">
                <h2 class="font-heading text-2xl text-cream mb-6 font-bold">
                    Artistes sur cette scène
                </h2>
                <div class="flex flex-col gap-6 lg:grid lg:grid-cols-2 lg:gap-8">
                    {artistes.map((artiste) => (
                        <ArtisteCard artiste={artiste} />
                    ))}
                </div>
                    </div>
                </div>
            </section>
        )
    }
    <!-- Bouton retour -->
    <div class="px-6 mt-8 text-center">
        <div class="mygrid">
            <div class="lg:col-start-3 lg:col-span-8">
        <a
            href="/scenes"
            class="inline-block bg-accent text-primary font-body px-6 py-2 rounded-full border-2 border-accent hover:bg-transparent hover:text-accent transition-colors"
        >
            ← Toutes les scènes
        </a>
            </div>
        </div>
    </div>
</Layout>
