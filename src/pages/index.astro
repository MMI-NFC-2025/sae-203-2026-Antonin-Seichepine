---
import Layout from "../layouts/Layout.astro";
import { getArtistesByDate, getImageUrl } from "../js/backend.mjs";

// Récupérer les artistes pour le carrousel
const artistes = await getArtistesByDate();
---

<Layout titre="Accueil">
	<!-- Hero Section -->
	<section class="relative bg-primary-light">
		<div
			class="relative h-[70vh] flex flex-col items-center justify-center text-center px-6 bg-[url('/hero-bg.jpg')] bg-cover bg-center"
		>
			<!-- Overlay sombre -->
			<div class="absolute inset-0 bg-primary/70"></div>

			<div class="relative z-10">
				<h1 class="font-heading text-5xl md:text-7xl text-cream mb-4">
					Festicloze
				</h1>
				<p
					class="font-heading text-xl md:text-2xl text-cream-dark mb-2"
				>
					La magie de Noël au cœur
				</p>
				<p
					class="font-heading text-xl md:text-2xl text-cream-dark mb-8"
				>
					de la musique baroque
				</p>

				<div
					class="bg-cream/20 rounded-full px-6 py-3 inline-block mb-4"
				>
					<p class="text-cream font-bold">20 - 23 Décembre 2025</p>
					<p class="text-cream-dark text-sm">Montbéliard</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Chiffres clés -->
	<section class="py-10 px-6">
		<div class="grid grid-cols-3 gap-4 max-w-md mx-auto text-center">
			<div class="flex flex-col items-center gap-2">
				<div
					class="w-14 h-14 bg-accent rounded-full flex items-center justify-center"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						class="h-7 w-7 text-primary"
						fill="none"
						viewBox="0 0 24 24"
						stroke="currentColor"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"
						></path>
					</svg>
				</div>
				<p class="text-cream text-sm">3 jours de concerts</p>
			</div>
			<div class="flex flex-col items-center gap-2">
				<div
					class="w-14 h-14 bg-accent rounded-full flex items-center justify-center"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						class="h-7 w-7 text-primary"
						fill="none"
						viewBox="0 0 24 24"
						stroke="currentColor"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"
						></path>
					</svg>
				</div>
				<p class="text-cream text-sm">Plusieurs artistes</p>
			</div>
			<div class="flex flex-col items-center gap-2">
				<div
					class="w-14 h-14 bg-accent rounded-full flex items-center justify-center"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						class="h-7 w-7 text-primary"
						fill="none"
						viewBox="0 0 24 24"
						stroke="currentColor"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
						></path>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
					</svg>
				</div>
				<p class="text-cream text-sm">3 lieux</p>
			</div>
		</div>
	</section>

	<!-- Bouton CTA -->
	<section class="px-6 pb-10">
		<div class="bg-primary-light py-6 text-center">
			<a
				href="#"
				class="inline-block border-2 border-accent text-accent font-heading text-lg px-8 py-3 rounded-full hover:bg-accent hover:text-primary transition-colors"
			>
				Réserver mes places
			</a>
		</div>
	</section>

	<!-- Carrousel artistes -->
	<section class="px-6 pb-12">
		<div class="relative overflow-hidden rounded-xl max-w-md mx-auto">
			<div id="carrousel" class="flex transition-transform duration-500">
				{
					artistes.map((artiste) => (
						<div class="w-full flex-shrink-0">
							<a href={`/artistes/${artiste.id}`}>
								<img
									src={getImageUrl(artiste, artiste.photo)}
									alt={artiste.nom_artiste}
									class="w-full h-64 object-cover rounded-xl"
								/>
							</a>
						</div>
					))
				}
			</div>
			<!-- Flèches navigation -->
			<button
				id="prev"
				class="absolute left-2 top-1/2 -translate-y-1/2 text-cream text-3xl bg-primary/50 rounded-full w-10 h-10 flex items-center justify-center"
				>&lt;</button
			>
			<button
				id="next"
				class="absolute right-2 top-1/2 -translate-y-1/2 text-cream text-3xl bg-primary/50 rounded-full w-10 h-10 flex items-center justify-center"
				>&gt;</button
			>
			<!-- Indicateurs -->
			<div class="flex justify-center gap-2 mt-4">
				{
					artistes.map((_, i) => (
						<span
							class={`w-3 h-3 rounded-full ${i === 0 ? "bg-accent" : "bg-cream/40"}`}
							data-dot={i}
						/>
					))
				}
			</div>
		</div>
	</section>
</Layout>

<script>
	// @ts-nocheck
	const carrousel = document.getElementById("carrousel");
	const prev = document.getElementById("prev");
	const next = document.getElementById("next");
	const dots = document.querySelectorAll("[data-dot]");
	let current = 0;
	const total = carrousel.children.length;

	function goTo(index) {
		current = (index + total) % total;
		carrousel.style.transform = `translateX(-${current * 100}%)`;
		dots.forEach((dot, i) => {
			dot.classList.toggle("bg-accent", i === current);
			dot.classList.toggle("bg-cream/40", i !== current);
		});
	}

	prev.addEventListener("click", () => goTo(current - 1));
	next.addEventListener("click", () => goTo(current + 1));
</script>
