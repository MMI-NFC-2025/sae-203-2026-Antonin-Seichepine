---
// Header.astro — Navigation principale Festicloze
---

<header class="flex items-center justify-between px-6 py-4 bg-primary">
    <!-- Logo + Nom -->
    <a href="/" class="flex items-center gap-2">
        <img src="/logo.svg" alt="Festicloze" class="h-10 w-10" />
        <span class="font-heading text-cream text-xl">Festicloze</span>
    </a>

    <!-- Bouton burger (mobile) -->
    <button
        id="menu-toggle"
        class="text-cream md:hidden"
        aria-label="Ouvrir le menu"
    >
        <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-8 w-8"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
        >
            <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
    </button>

    <!-- Navigation desktop -->
    <nav class="hidden md:flex gap-6">
        <a
            href="/programme"
            class="text-cream hover:text-accent transition-colors">Programmes</a
        >
        <a
            href="/artistes"
            class="text-cream hover:text-accent transition-colors">Artistes</a
        >
        <a href="/scenes" class="text-cream hover:text-accent transition-colors"
            >Scènes</a
        >
        <a
            href="/a-propos"
            class="text-cream hover:text-accent transition-colors">À propos</a
        >
        <a
            href="/contact"
            class="text-cream hover:text-accent transition-colors">Contact</a
        >
        <a
            href="/infos-pratiques"
            class="text-cream hover:text-accent transition-colors"
            >Infos pratiques</a
        >
    </nav>
</header>

<!-- Menu mobile (plein écran) -->
<div
    id="mobile-menu"
    class="fixed inset-0 bg-primary z-50 flex-col px-10 hidden"
>
    <!-- Header du menu mobile -->
    <div class="flex items-center justify-between py-4">
        <a href="/" class="flex items-center gap-2">
            <img src="/logo.svg" alt="Festicloze" class="h-10 w-10" />
            <span class="font-heading text-cream text-xl">Festicloze</span>
        </a>
        <button id="menu-close" class="text-cream" aria-label="Fermer le menu">
            <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-8 w-8"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M6 18L18 6M6 6l12 12"></path>
            </svg>
        </button>
    </div>

    <!-- Liens du menu mobile -->
    <nav class="flex flex-col gap-6 mt-12">
        <a
            href="/programme"
            class="menu-link font-heading text-cream text-4xl hover:text-accent transition-colors opacity-0 translate-y-4"
            >Programmes</a
        >
        <a
            href="/artistes"
            class="menu-link font-heading text-cream text-4xl hover:text-accent transition-colors opacity-0 translate-y-4"
            >Artistes</a
        >
        <a
            href="/scenes"
            class="menu-link font-heading text-cream text-4xl hover:text-accent transition-colors opacity-0 translate-y-4"
            >Scènes</a
        >
        <a
            href="/a-propos"
            class="menu-link font-heading text-cream text-4xl hover:text-accent transition-colors opacity-0 translate-y-4"
            >À propos</a
        >
        <a
            href="/contact"
            class="menu-link font-heading text-cream text-4xl hover:text-accent transition-colors opacity-0 translate-y-4"
            >Contact</a
        >
        <a
            href="/infos-pratiques"
            class="menu-link font-heading text-cream text-4xl hover:text-accent transition-colors opacity-0 translate-y-4"
            >Infos pratiques</a
        >
    </nav>
</div>

<script>
    // @ts-nocheck
    const menuToggle = document.getElementById("menu-toggle");
    const menuClose = document.getElementById("menu-close");
    const mobileMenu = document.getElementById("mobile-menu");
    const menuLinks = document.querySelectorAll(".menu-link");

    // Ouvrir le menu avec animation en vague
    menuToggle.addEventListener("click", () => {
        mobileMenu.classList.remove("hidden");
        mobileMenu.classList.add("flex");

        // Animation en vague : chaque lien apparaît avec un délai
        menuLinks.forEach((link, i) => {
            link.classList.remove("opacity-0", "translate-y-4");
            link.classList.add("opacity-0", "translate-y-4");

            setTimeout(() => {
                link.style.transition =
                    "opacity 0.4s ease, transform 0.4s ease";
                link.classList.remove("opacity-0", "translate-y-4");
                link.classList.add("opacity-100", "translate-y-0");
            }, 100 * i);
        });
    });

    // Fermer le menu
menuClose.addEventListener('click', () => {
  // Fade out smooth
  mobileMenu.style.transition = 'opacity 0.3s ease';
  mobileMenu.style.opacity = '0';

  setTimeout(() => {
    mobileMenu.classList.add('hidden');
    mobileMenu.classList.remove('flex');
    mobileMenu.style.opacity = '1';
    // Reset des liens pour la prochaine ouverture
    menuLinks.forEach((link) => {
      link.classList.remove('opacity-100', 'translate-y-0');
      link.classList.add('opacity-0', 'translate-y-4');
    });
  }, 300);
});
</script>
